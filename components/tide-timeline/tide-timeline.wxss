.timeline { padding: 12rpx 0; }
.timeline-item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 8rpx 0;
  border-left: 2rpx solid #8BA4B8;
  margin-left: 12rpx;
  padding-left: 16rpx;
}
.timeline-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  flex-shrink: 0;
}
.timeline-dot.high { background-color: #E74C3C; }
.timeline-dot.low { background-color: #3498DB; }
.timeline-content { display: flex; gap: 12rpx; align-items: center; }
.timeline-time { font-size: 26rpx; color: #E8F0F2; }
.timeline-height { font-size: 24rpx; color: #2D8B6F; font-weight: bold; }
.timeline-type { font-size: 22rpx; color: #8BA4B8; }
