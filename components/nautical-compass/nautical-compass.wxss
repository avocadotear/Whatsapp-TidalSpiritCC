.compass-section {
  background: linear-gradient(135deg, rgba(13, 43, 78, 0.95), rgba(10, 22, 40, 0.98));
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(45, 200, 160, 0.15);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.compass-title-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.compass-icon-text {
  font-size: 32rpx;
}

.compass-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #E8F0F2;
  letter-spacing: 2rpx;
}

.compass-canvas-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
}

.compass-canvas {
  width: 300rpx;
  height: 300rpx;
}

.compass-info {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-around;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.info-label {
  font-size: 20rpx;
  color: #8BA4B8;
}

.info-value {
  font-size: 24rpx;
  color: #E8F0F2;
  font-weight: bold;
}

.info-value.wind {
  color: #2DD4AA;
}

.compass-suggestion {
  background: rgba(45, 200, 160, 0.08);
  border: 1rpx solid rgba(45, 200, 160, 0.2);
  border-radius: 10rpx;
  padding: 16rpx;
}

.suggestion-text {
  font-size: 22rpx;
  color: #8BA4B8;
  line-height: 1.5;
}
