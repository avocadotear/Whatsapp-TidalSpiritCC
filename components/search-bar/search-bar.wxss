.search-bar {
  padding: 12rpx 20rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #1A3A5C;
  border-radius: 30rpx;
  padding: 12rpx 20rpx;
  border: 1rpx solid rgba(139, 164, 184, 0.3);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #E8F0F2;
}

.clear-btn {
  font-size: 26rpx;
  color: #8BA4B8;
  padding: 4rpx 8rpx;
}
