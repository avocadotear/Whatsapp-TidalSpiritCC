<view class="chart-container">
  <canvas
    type="2d"
    id="tideCanvas"
    class="tide-canvas"
    canvas-id="{{canvasId}}"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  ></canvas>

  <!-- Hour detail card -->
  <view class="hour-card {{showTooltip ? 'show' : ''}}" wx:if="{{showTooltip}}">
    <view class="hour-card-top">
      <text class="hour-card-time">{{tooltipTime}}</text>
      <text class="hour-card-height">{{tooltipHeight}}</text>
      <text class="hour-card-trend">{{tooltipTrend}}</text>
    </view>
    <view class="hour-card-mid">
      <text class="hour-card-label">赶海建议</text>
      <text class="hour-card-advice {{tooltipAdvice === '非常适合' ? 'excellent' : tooltipAdvice === '适合' ? 'good' : 'bad'}}">{{tooltipAdvice}}</text>
    </view>
    <view class="hour-card-bottom">
      <text class="hour-card-sea">{{tooltipSeaState}}</text>
    </view>
  </view>

  <!-- Hour timeline scrollbar -->
  <scroll-view class="hour-scroll" scroll-x scroll-into-view="hour-{{snapIndex}}" scroll-with-animation>
    <view class="hour-list">
      <view
        wx:for="{{hourItems}}"
        wx:key="hour"
        id="hour-{{index}}"
        class="hour-chip {{selectedHour === item.hour ? 'active' : ''}}"
        data-hour="{{item.hour}}"
        bindtap="onHourTap"
      >
        <text class="hour-chip-label">{{item.label}}</text>
      </view>
    </view>
  </scroll-view>
</view>
