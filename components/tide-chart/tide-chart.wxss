.chart-container {
  width: 100%;
  background-color: #0A1628;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.tide-canvas {
  width: 100%;
  height: 450rpx;
}

/* Hour detail card */
.hour-card {
  margin: 0 16rpx 12rpx;
  background: rgba(13, 43, 78, 0.92);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(45, 200, 160, 0.3);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  opacity: 0;
  transform: translateY(-8rpx);
  transition: opacity 0.3s ease, transform 0.3s ease;
  pointer-events: none;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.hour-card.show {
  opacity: 1;
  transform: translateY(0);
}

.hour-card-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.hour-card-time {
  font-size: 30rpx;
  color: #F5A623;
  font-weight: bold;
}

.hour-card-height {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.hour-card-trend {
  font-size: 22rpx;
  color: #2DD4AA;
  margin-left: auto;
}

.hour-card-mid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
  padding: 8rpx 12rpx;
  background: rgba(45, 200, 160, 0.06);
  border-radius: 8rpx;
}

.hour-card-label {
  font-size: 22rpx;
  color: #8BA4B8;
}

.hour-card-advice {
  font-size: 24rpx;
  font-weight: bold;
}

.hour-card-advice.excellent { color: #2DD4AA; }
.hour-card-advice.good { color: #F5A623; }
.hour-card-advice.bad { color: #E74C3C; }

.hour-card-bottom {
  padding: 4rpx 0;
}

.hour-card-sea {
  font-size: 20rpx;
  color: #8BA4B8;
  line-height: 1.5;
}

/* Hour timeline scrollbar */
.hour-scroll {
  white-space: nowrap;
  padding: 12rpx 16rpx;
  border-top: 1rpx solid rgba(139, 164, 184, 0.1);
}

.hour-list {
  display: inline-flex;
  gap: 8rpx;
}

.hour-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background-color: rgba(18, 42, 69, 0.8);
  border: 1rpx solid rgba(139, 164, 184, 0.15);
  min-width: 72rpx;
}

.hour-chip.active {
  background-color: rgba(245, 166, 35, 0.2);
  border-color: rgba(245, 166, 35, 0.5);
}

.hour-chip-label {
  font-size: 22rpx;
  color: #8BA4B8;
}

.hour-chip.active .hour-chip-label {
  color: #F5A623;
  font-weight: bold;
}
