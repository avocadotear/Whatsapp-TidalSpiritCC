.chart-container {
  width: 100%;
  background-color: #0A1628;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.tide-canvas {
  width: 100%;
  height: 450rpx;
}

.tooltip {
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%) translateY(-10rpx);
  background: rgba(10, 22, 40, 0.92);
  border: 1rpx solid rgba(245, 166, 35, 0.35);
  border-radius: 10rpx;
  padding: 12rpx 20rpx;
  min-width: 340rpx;
  opacity: 0;
  transition: opacity 0.25s ease, transform 0.25s ease;
  pointer-events: none;
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.tooltip.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.tooltip-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.tooltip-row:last-child {
  margin-bottom: 0;
}

.tooltip-time {
  font-size: 28rpx;
  color: #F5A623;
  font-weight: bold;
}

.tooltip-height {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.tooltip-label {
  font-size: 20rpx;
  color: #8BA4B8;
}

.tooltip-value {
  font-size: 20rpx;
  color: #E8F0F2;
  font-weight: bold;
}

.tooltip-value.excellent { color: #2DD4AA; }
.tooltip-value.good { color: #F5A623; }
.tooltip-value.bad { color: #E74C3C; }

.tooltip-sea {
  font-size: 18rpx;
  color: #8BA4B8;
  line-height: 1.4;
}
