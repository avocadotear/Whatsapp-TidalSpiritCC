<view class="bagua-section">
  <view class="bagua-title-bar">
    <text class="bagua-icon-text">☯</text>
    <text class="bagua-title">八卦算盘 · 赶海预测</text>
  </view>

  <view class="bagua-canvas-wrap" bindtap="onTapCalculate">
    <canvas
      type="2d"
      id="baguaCanvas"
      class="bagua-canvas"
    ></canvas>
    <view class="tap-hint" wx:if="{{!isCalculating && !showResult}}">
      <text class="tap-hint-text">点击开始测算</text>
    </view>
    <view class="calculating-overlay" wx:if="{{isCalculating}}">
      <view class="calc-ring">
        <view class="calc-dot"></view>
      </view>
      <text class="calc-text">{{resultText}}</text>
    </view>
  </view>

  <view class="factors-grid">
    <view class="factor-item" wx:for="{{factors}}" wx:key="label">
      <text class="factor-icon">{{item.icon}}</text>
      <text class="factor-label">{{item.label}}</text>
      <text class="factor-value">{{item.value}}</text>
    </view>
  </view>

  <view class="prediction-result {{resultClass}}" wx:if="{{showResult || !showResult}}">
    <view class="result-header">
      <text class="result-level">{{resultLevel}}</text>
      <text class="result-retry" wx:if="{{showResult}}" bindtap="onTapCalculate">重新测算</text>
    </view>
    <view class="result-text" wx:if="{{resultText}}">{{resultText}}</view>
  </view>
</view>
