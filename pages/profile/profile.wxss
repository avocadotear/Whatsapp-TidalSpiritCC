.container {
  background-color: #0A1628;
  min-height: 100vh;
}

/* User Banner */
.user-banner {
  position: relative;
  padding: 60rpx 20rpx 40rpx;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #0D2B4E 0%, #1A3A5C 50%, #0A1628 100%);
}

.user-info {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: #122A45;
  border: 4rpx solid #2D8B6F;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.avatar-text { font-size: 60rpx; }

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 22rpx;
  color: #8BA4B8;
}

.user-note {
  font-size: 22rpx;
  color: #F5A623;
}

.version {
  font-size: 22rpx;
  color: #8BA4B8;
}

/* Menu */
.menu-section {
  margin: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background-color: #122A45;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #E8F0F2;
}

.menu-arrow {
  font-size: 32rpx;
  color: #8BA4B8;
}

/* Favorites */
.fav-section {
  margin: 20rpx;
  background-color: #122A45;
  border-radius: 12rpx;
  padding: 20rpx;
}

.fav-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #E8F0F2;
  margin-bottom: 16rpx;
  display: block;
}

.fav-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.fav-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background-color: #1A3A5C;
  border-radius: 8rpx;
}

.fav-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.fav-name {
  font-size: 26rpx;
  color: #E8F0F2;
}

.fav-desc {
  font-size: 20rpx;
  color: #8BA4B8;
  margin-top: 4rpx;
}

.fav-remove {
  font-size: 22rpx;
  color: #E74C3C;
  padding: 8rpx 16rpx;
  background-color: rgba(231,76,60,0.1);
  border-radius: 6rpx;
}

.bottom-space { height: 40rpx; }
