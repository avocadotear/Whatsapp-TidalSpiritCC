<view class="container">
  <!-- Search Bar -->
  <search-bar placeholder="输入要查找地方（两边按钮确认）" bind:search="onSearch" />

  <!-- Distance Bar -->
  <view class="distance-bar">
    <text class="distance-label">附近100公里：</text>
    <view class="recalc-btn" bindtap="recalcDistance">
      <text>重新计算距离</text>
    </view>
  </view>

  <!-- Main Content: Sidebar + List -->
  <view class="main-content">
    <sidebar items="{{provinces}}" current="{{currentProvince}}" bind:select="onSidebarSelect" />

    <scroll-view class="region-list" scroll-y>
      <block wx:if="{{regions.length > 0}}">
        <location-card
          wx:for="{{regions}}"
          wx:key="id"
          region="{{item}}"
          tideInfo="{{item.tideInfo}}"
          mode="{{mode}}"
          selectedDate="{{selectedDate}}"
        />
      </block>
      <view wx:else class="empty-state">
        <text>暂无该区域的赶海点</text>
      </view>
    </scroll-view>
  </view>

  <!-- Floating Mode Toggle -->
  <view class="float-btn {{mode === 'fishing' ? 'fishing' : 'beachcombing'}}" bindtap="toggleMode">
    <text class="float-icon">{{mode === 'fishing' ? '🐟' : '🦀'}}</text>
    <text class="float-text">{{mode === 'fishing' ? '钓鱼模式' : '赶海模式'}}</text>
  </view>

  <!-- Bottom Date Bar -->
  <view class="date-bar">
    <scroll-view class="date-scroll" scroll-x>
      <view class="date-list">
        <view
          wx:for="{{dates}}"
          wx:key="date"
          class="date-item {{selectedDate === item.date ? 'active' : ''}}"
          data-date="{{item.date}}"
          bindtap="onDateSelect"
        >
          <text class="date-day">{{item.day}}</text>
          <text class="date-attr">{{item.attribute}}</text>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
