.container {
  background-color: #0A1628;
  min-height: 100vh;
}

.top-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: #0D2B4E;
  gap: 12rpx;
}

.camera-btn {
  font-size: 40rpx;
  background-color: #E74C3C;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.search-wrap {
  flex: 1;
  background-color: #1A3A5C;
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(139,164,184,0.3);
}

.search-input {
  font-size: 24rpx;
  color: #E8F0F2;
}

.search-btn {
  font-size: 36rpx;
  padding: 4rpx;
}

.identify-area {
  margin: 24rpx 20rpx;
  background-color: #122A45;
  border-radius: 16rpx;
  overflow: hidden;
  min-height: 400rpx;
}

.identify-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 20rpx;
}

.identify-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 24rpx;
}

.identify-icon-box {
  width: 160rpx;
  height: 160rpx;
  border: 4rpx dashed #8BA4B8;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.identify-icon { font-size: 60rpx; }

.identify-hint {
  font-size: 28rpx;
  color: #E8F0F2;
  margin-bottom: 8rpx;
}

.identify-sub {
  font-size: 22rpx;
  color: #8BA4B8;
}

.identify-preview {
  position: relative;
  width: 100%;
  min-height: 400rpx;
}

.preview-image {
  width: 100%;
  height: 400rpx;
}

.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(10, 22, 40, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 32rpx;
  color: #2D8B6F;
  font-weight: bold;
}

.identify-note {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #8BA4B8;
  padding: 0 20rpx;
  margin-bottom: 24rpx;
}

/* Result */
.result-card {
  margin: 0 20rpx 24rpx;
  background-color: #122A45;
  border-radius: 12rpx;
  padding: 24rpx;
  position: relative;
}

.result-close {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  font-size: 28rpx;
  color: #8BA4B8;
}

.result-header { margin-bottom: 12rpx; }

.result-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
}

.result-latin {
  font-size: 22rpx;
  color: #8BA4B8;
  font-style: italic;
}

.result-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #E8F0F2;
  line-height: 1.6;
}

/* History */
.history-section {
  margin: 0 20rpx;
  background-color: #122A45;
  border-radius: 12rpx;
  padding: 20rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #E8F0F2;
}

.clear-btn {
  font-size: 22rpx;
  color: #E74C3C;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  background-color: #1A3A5C;
  border-radius: 8rpx;
}

.history-name {
  font-size: 26rpx;
  color: #E8F0F2;
  flex: 1;
}

.history-category {
  font-size: 22rpx;
  color: #8BA4B8;
}

.history-confidence {
  font-size: 22rpx;
  color: #2D8B6F;
  font-weight: bold;
}

.bottom-space { height: 40rpx; }
